<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  LibreNMS Home Lab — Complete Build Configuration Reference
  ============================================================
  
  This file documents all configuration values used across
  the LibreNMS installation on Ubuntu Server 22.04 LTS.
  
  SANITIZED FOR PUBLIC USE — replace all placeholder values:
  
    YOUR_SERVER_IP        → Host-only IP of LibreNMS server (e.g. 192.168.56.102)
    YOUR_KALI_IP          → Host-only IP of Kali VM (e.g. 192.168.56.103)
    YOUR_HOST_SUBNET      → Host-only subnet (e.g. 192.168.56.0/24)
    YOUR_USERNAME         → Your Ubuntu login username
    YOUR_HOSTNAME         → Your server hostname (e.g. theone)
    YOUR_DB_PASSWORD      → MariaDB password for the librenms user
    YOUR_COMMUNITY_STRING → SNMP community string (treat like a password)
    YOUR_APP_KEY          → Generated by: sudo -u librenms php artisan key:generate
  
  ============================================================
-->

<librenms-lab-config>

  <!-- ══════════════════════════════════════════════════════
       ENVIRONMENT
       ══════════════════════════════════════════════════════ -->
  <environment>
    <host>
      <machine>ThinkPad T490</machine>
      <os>Windows 10</os>
      <hypervisor>Oracle VirtualBox</hypervisor>
    </host>

    <server-vm>
      <hostname>YOUR_HOSTNAME</hostname>
      <os>Ubuntu Server 22.04 LTS</os>
      <ram>4096MB</ram>
      <cpu>2 cores</cpu>
      <disk>40GB dynamically allocated</disk>
      <adapter1>Host-only — YOUR_HOST_SUBNET</adapter1>
      <adapter2>NAT — internet/apt access</adapter2>
      <ip-hostonly>YOUR_SERVER_IP</ip-hostonly>
      <ip-nat>10.0.2.15 (VirtualBox NAT — dynamic)</ip-nat>
    </server-vm>

    <kali-vm>
      <hostname>kali</hostname>
      <os>Kali Linux (rolling)</os>
      <adapter1>Host-only — YOUR_HOST_SUBNET</adapter1>
      <adapter2>NAT — internet/apt access</adapter2>
      <ip-hostonly>YOUR_KALI_IP</ip-hostonly>
      <role>SNMP Agent — monitored device</role>
    </kali-vm>

    <network>
      <host-only-subnet>YOUR_HOST_SUBNET</host-only-subnet>
      <host-only-purpose>VM-to-VM and host-to-VM communication</host-only-purpose>
      <nat-purpose>Outbound internet for apt package downloads</nat-purpose>
      <snmp-port>UDP/161 — polling</snmp-port>
      <snmp-trap-port>UDP/162 — not configured in this build</snmp-trap-port>
    </network>
  </environment>


  <!-- ══════════════════════════════════════════════════════
       STACK VERSIONS
       ══════════════════════════════════════════════════════ -->
  <stack>
    <component name="LibreNMS"   version="26.7.0-dev" />
    <component name="PHP"        version="8.5.4" />
    <component name="Python"     version="3.14.4" />
    <component name="MariaDB"    version="11.8.6-MariaDB-5 (Ubuntu)" />
    <component name="Nginx"      version="1.28.3 (Ubuntu)" />
    <component name="RRDTool"    version="1.9.0" />
    <component name="SNMP"       version="5.9.4.pre2" />
    <component name="Composer"   version="2.10.1" />
    <component name="OS"         version="Ubuntu Server 22.04.5 LTS" />
  </stack>


  <!-- ══════════════════════════════════════════════════════
       MARIADB CONFIGURATION
       File: /etc/mysql/mariadb.conf.d/50-server.cnf
       ══════════════════════════════════════════════════════ -->
  <mariadb>
    <config-file>/etc/mysql/mariadb.conf.d/50-server.cnf</config-file>
    <section name="[mysqld]">
      <!-- Added under [mysqld] — not present by default -->
      <setting key="innodb_file_per_table"   value="1"
        reason="Stores each table in its own file — better performance and recovery" />
      <setting key="lower_case_table_names"  value="0"
        reason="Case-sensitive table names — required by LibreNMS" />
    </section>

    <database>
      <name>librenms</name>
      <charset>utf8mb4</charset>
      <collation>utf8mb4_unicode_ci</collation>
      <user>librenms</user>
      <host>localhost</host>
      <password>YOUR_DB_PASSWORD</password>
      <privileges>ALL PRIVILEGES ON librenms.*</privileges>
    </database>

    <creation-commands>
      <cmd>CREATE DATABASE librenms CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;</cmd>
      <cmd>CREATE USER 'librenms'@'localhost' IDENTIFIED BY 'YOUR_DB_PASSWORD';</cmd>
      <cmd>GRANT ALL PRIVILEGES ON librenms.* TO 'librenms'@'localhost';</cmd>
    </creation-commands>
  </mariadb>


  <!-- ══════════════════════════════════════════════════════
       PHP-FPM POOL CONFIGURATION
       File: /etc/php/8.5/fpm/pool.d/librenms.conf
       Copied from: www.conf and modified
       ══════════════════════════════════════════════════════ -->
  <php-fpm>
    <config-file>/etc/php/8.5/fpm/pool.d/librenms.conf</config-file>
    <source-file>/etc/php/8.5/fpm/pool.d/www.conf</source-file>

    <changes>
      <!--
        IMPORTANT NOTE on listen.owner vs user:
        
        user/group        = what Linux user PHP worker PROCESSES run as
        listen.owner/group = who can ACCESS the socket FILE
        
        These are two separate settings with different jobs.
        Changing listen.owner to librenms broke nginx access (502 Bad Gateway)
        because nginx runs as www-data and lost access to the socket.
        Keep listen.owner/group as www-data.
      -->
      <change from="[www]"              to="[librenms]"
        reason="Name the pool — must match nginx fastcgi_pass reference" />
      <change from="user = www-data"    to="user = librenms"
        reason="PHP processes run as librenms user matching file ownership" />
      <change from="group = www-data"   to="group = librenms"
        reason="PHP processes run as librenms group matching file ownership" />
      <change from="listen = ..."       to="listen = /run/php/php-fpm-librenms.sock"
        reason="Socket path nginx uses — must match fastcgi_pass in nginx config" />
      <change from="listen.owner = www-data" to="leave as www-data"
        reason="Nginx (www-data) must own the socket to access it — DO NOT change" />
      <change from="listen.group = www-data" to="leave as www-data"
        reason="Nginx (www-data) must own the socket to access it — DO NOT change" />
    </changes>

    <active-settings>
      <setting key="[pool]"          value="librenms" />
      <setting key="user"            value="librenms" />
      <setting key="group"           value="librenms" />
      <setting key="listen"          value="/run/php/php-fpm-librenms.sock" />
      <setting key="listen.owner"    value="www-data" />
      <setting key="listen.group"    value="www-data" />
      <setting key="pm"              value="dynamic" />
      <setting key="pm.max_children" value="5" />
      <setting key="pm.start_servers"      value="2" />
      <setting key="pm.min_spare_servers"  value="1" />
      <setting key="pm.max_spare_servers"  value="3" />
    </active-settings>
  </php-fpm>


  <!-- ══════════════════════════════════════════════════════
       NGINX CONFIGURATION
       File: /etc/nginx/conf.d/librenms.conf
       ══════════════════════════════════════════════════════ -->
  <nginx>
    <config-file>/etc/nginx/conf.d/librenms.conf</config-file>
    <removed-file>/etc/nginx/sites-enabled/default</removed-file>

    <server-block>
      <setting key="listen"      value="80" />
      <setting key="server_name" value="YOUR_SERVER_IP" />
      <setting key="root"        value="/opt/librenms/html" />
      <setting key="index"       value="index.php" />
      <setting key="charset"     value="utf-8" />
      <setting key="gzip"        value="on" />
    </server-block>

    <locations>
      <location path="/">
        <directive>try_files $uri $uri/ /index.php?$query_string</directive>
        <reason>Routes all requests through index.php — Laravel routing</reason>
      </location>

      <location path="~ [^/]\.php(/|$)">
        <directive>fastcgi_pass unix:/run/php/php-fpm-librenms.sock</directive>
        <directive>fastcgi_split_path_info ^(.+\.php)(/.+)$</directive>
        <directive>include fastcgi.conf</directive>
        <reason>Passes PHP requests to PHP-FPM via Unix socket</reason>
        <note>Socket path must exactly match listen = value in php-fpm pool config</note>
      </location>

      <location path="~ /\.(?!well-known).*">
        <directive>deny all</directive>
        <reason>Blocks access to hidden dot-files — prevents .env and .git exposure</reason>
      </location>
    </locations>

    <troubleshooting>
      <issue name="502 Bad Gateway">
        <cause>Socket path mismatch between nginx fastcgi_pass and PHP-FPM listen value</cause>
        <cause>listen.owner/group changed from www-data — nginx loses socket access</cause>
        <diagnosis>ls -la /run/php/ — check socket file exists and is owned by www-data</diagnosis>
        <diagnosis>sudo nginx -t — test config syntax before restarting</diagnosis>
      </issue>
      <issue name="403 Forbidden on assets">
        <cause>/opt/librenms/html permissions too restrictive for nginx to read files</cause>
        <fix>sudo chmod -R 755 /opt/librenms/html</fix>
        <followup>Tighten regular files: find /opt/librenms/html -type f -exec chmod 644 {} \;</followup>
      </issue>
    </troubleshooting>
  </nginx>


  <!-- ══════════════════════════════════════════════════════
       SNMP CONFIGURATION
       File: /etc/snmp/snmpd.conf
       ══════════════════════════════════════════════════════ -->
  <snmp>
    <config-file>/etc/snmp/snmpd.conf</config-file>
    <source-file>/opt/librenms/snmpd.conf.example</source-file>

    <settings>
      <setting key="rocommunity"  value="YOUR_COMMUNITY_STRING"
        note="Read-only community string — treat like a password, keep out of public repos" />
      <setting key="syslocation"  value="Lab, Home, City, Country" />
      <setting key="syscontact"   value="Your Name &lt;your@email.com&gt;" />
      <setting key="extend distro" value="/usr/bin/distro"
        note="Script downloaded from librenms-agent — reports OS distribution via SNMP" />
    </settings>

    <access-control>
      <entry>com2sec readonly default YOUR_COMMUNITY_STRING</entry>
      <entry>group MyROGroup v2c readonly</entry>
      <entry>view all included .1 80</entry>
      <entry>access MyROGroup "" any noauth exact all none none</entry>
    </access-control>

    <ports>
      <port protocol="UDP" number="161" direction="inbound"  purpose="SNMP queries (polling)" />
      <port protocol="UDP" number="162" direction="outbound" purpose="SNMP traps — NOT configured in this build" />
    </ports>

    <polling>
      <interval>5 minutes (LibreNMS default)</interval>
      <method>SNMP v2c polling — LibreNMS initiates, device responds</method>
      <version>SNMPv2c</version>
    </polling>

    <distro-script>
      <source>https://raw.githubusercontent.com/librenms/librenms-agent/master/snmp/distro</source>
      <destination>/usr/bin/distro</destination>
      <permissions>755 (executable)</permissions>
    </distro-script>
  </snmp>


  <!-- ══════════════════════════════════════════════════════
       LIBRENMS .env CONFIGURATION
       File: /opt/librenms/.env
       ══════════════════════════════════════════════════════ -->
  <librenms-env>
    <config-file>/opt/librenms/.env</config-file>
    <source-file>/opt/librenms/.env.example</source-file>

    <note>
      All DB_ lines are commented out (#) in the example file by default.
      Remove the # from each line or they will be ignored entirely.
      This caused the "Access denied (using password: NO)" error in this build.
    </note>

    <settings>
      <setting key="APP_KEY"      value="YOUR_APP_KEY"
        note="Generated by: cd /opt/librenms and sudo -u librenms php artisan key:generate" />
      <setting key="DB_HOST"      value="localhost" />
      <setting key="DB_DATABASE"  value="librenms" />
      <setting key="DB_USERNAME"  value="librenms" />
      <setting key="DB_PASSWORD"  value="YOUR_DB_PASSWORD" />
    </settings>
  </librenms-env>


  <!-- ══════════════════════════════════════════════════════
       FILE PERMISSIONS
       ══════════════════════════════════════════════════════ -->
  <permissions>
    <note>
      Permissions were the source of multiple errors in this build.
      Document them explicitly for reference.
    </note>

    <entry path="/opt/librenms"
      owner="librenms:librenms"
      mode="771"
      reason="Owner/group full access, others execute-only — can enter but not read/write" />

    <entry path="/opt/librenms/html"
      owner="librenms:librenms"
      mode="755 (directories) / 644 (files)"
      reason="nginx (www-data/others) needs read access to serve CSS and JS assets" />

    <entry path="/opt/librenms/rrd"
      owner="librenms:librenms"
      mode="ACL g::rwx (default + recursive)"
      reason="LibreNMS writes RRD graph data here continuously" />

    <entry path="/opt/librenms/logs"
      owner="librenms:librenms"
      mode="ACL g::rwx (default + recursive)"
      reason="LibreNMS writes application logs here" />

    <entry path="/opt/librenms/bootstrap/cache"
      owner="librenms:librenms"
      mode="ACL g::rwx (default + recursive)"
      reason="Laravel PHP framework cache" />

    <entry path="/opt/librenms/storage"
      owner="librenms:librenms"
      mode="ACL g::rwx (default + recursive)"
      reason="General application storage — sessions, temp files" />

    <entry path="/run/php/php-fpm-librenms.sock"
      owner="www-data:www-data"
      mode="srw-rw----"
      reason="Socket owned by www-data so nginx can connect to it" />

    <entry path="/usr/bin/distro"
      owner="root:root"
      mode="755"
      reason="SNMP distro script must be executable" />

    <acl-commands>
      <cmd>sudo setfacl -d -m g::rwx /opt/librenms/rrd /opt/librenms/logs /opt/librenms/bootstrap/cache/ /opt/librenms/storage/</cmd>
      <cmd>sudo setfacl -R -m g::rwx /opt/librenms/rrd /opt/librenms/logs /opt/librenms/bootstrap/cache/ /opt/librenms/storage/</cmd>
      <cmd>sudo chmod -R 755 /opt/librenms/html</cmd>
      <cmd>find /opt/librenms/html -type f -exec chmod 644 {} \;</cmd>
    </acl-commands>
  </permissions>


  <!-- ══════════════════════════════════════════════════════
       SYSTEMD SERVICES
       ══════════════════════════════════════════════════════ -->
  <services>
    <service name="nginx"
      config="/etc/nginx/conf.d/librenms.conf"
      status-cmd="sudo systemctl status nginx"
      restart-cmd="sudo systemctl restart nginx"
      test-cmd="sudo nginx -t" />

    <service name="php8.5-fpm"
      config="/etc/php/8.5/fpm/pool.d/librenms.conf"
      status-cmd="sudo systemctl status php8.5-fpm"
      restart-cmd="sudo systemctl restart php8.5-fpm" />

    <service name="mariadb"
      config="/etc/mysql/mariadb.conf.d/50-server.cnf"
      status-cmd="sudo systemctl status mariadb"
      restart-cmd="sudo systemctl restart mariadb" />

    <service name="snmpd"
      config="/etc/snmp/snmpd.conf"
      status-cmd="sudo systemctl status snmpd"
      restart-cmd="sudo systemctl restart snmpd"
      test-cmd="snmpwalk -v2c -c YOUR_COMMUNITY_STRING 127.0.0.1" />

    <service name="librenms-scheduler.timer"
      purpose="Triggers LibreNMS polling scheduler"
      status-cmd="sudo systemctl status librenms-scheduler.timer"
      enable-cmd="sudo systemctl enable librenms-scheduler.timer"
      start-cmd="sudo systemctl start librenms-scheduler.timer" />
  </services>


  <!-- ══════════════════════════════════════════════════════
       CRON & SCHEDULER
       ══════════════════════════════════════════════════════ -->
  <scheduler>
    <cron-file source="/opt/librenms/dist/librenms.cron"
      destination="/etc/cron.d/librenms"
      purpose="Polls all devices every 5 minutes automatically" />

    <scheduler-service
      source="/opt/librenms/dist/librenms-scheduler.service"
      destination="/etc/systemd/system/librenms-scheduler.service" />

    <scheduler-timer
      source="/opt/librenms/dist/librenms-scheduler.timer"
      destination="/etc/systemd/system/librenms-scheduler.timer" />

    <logrotate
      source="/opt/librenms/misc/librenms.logrotate"
      destination="/etc/logrotate.d/librenms"
      purpose="Prevents log files from growing indefinitely" />
  </scheduler>


  <!-- ══════════════════════════════════════════════════════
       PYTHON DEPENDENCIES
       ══════════════════════════════════════════════════════ -->
  <python-deps>
    <install-cmd>sudo pip3 install -r /opt/librenms/requirements.txt --break-system-packages</install-cmd>
    <note>
      Must install system-wide with sudo — not per-user.
      Installing without sudo puts packages in /home/USERNAME/.local which
      the librenms user cannot see. This caused the [FAIL] command_runner
      error in validate.php during this build.
      --break-system-packages required on Ubuntu 22.04+ to override
      Python environment protection.
    </note>
    <required-packages>
      <package name="PyMySQL"        version="!=1.0.0" />
      <package name="python-dotenv"  version="any" />
      <package name="redis"          version=">=4.0" />
      <package name="setuptools"     version="any" />
      <package name="psutil"         version=">=5.9.6" />
      <package name="command_runner" version=">=1.3.0" />
    </required-packages>
  </python-deps>


  <!-- ══════════════════════════════════════════════════════
       LIBRENMS SYSTEM USER
       ══════════════════════════════════════════════════════ -->
  <system-user>
    <username>librenms</username>
    <home>/opt/librenms</home>
    <shell>/bin/bash</shell>
    <type>system account (no login)</type>
    <creation-cmd>sudo useradd librenms -d /opt/librenms -M -r -s "$(which bash)"</creation-cmd>
    <group-add-cmd>sudo usermod -aG librenms YOUR_USERNAME</group-add-cmd>
    <reason>
      Least privilege — LibreNMS runs as its own isolated user.
      Not root, not www-data, not your personal account.
      All application files owned by this user.
    </reason>
  </system-user>


  <!-- ══════════════════════════════════════════════════════
       VALIDATION
       ══════════════════════════════════════════════════════ -->
  <validation>
    <command>sudo -u librenms php /opt/librenms/validate.php</command>
    <final-result>
      <ok>Composer Version: 2.10.1</ok>
      <ok>Dependencies up-to-date</ok>
      <ok>Database Connected</ok>
      <ok>Database Schema is current</ok>
      <ok>SQL Server meets minimum requirements</ok>
      <ok>lower_case_table_names is enabled</ok>
      <ok>MySQL engine is optimal</ok>
      <ok>Database and column collations are correct</ok>
      <ok>Database schema correct</ok>
      <ok>MySQL and PHP time match</ok>
      <ok>Active pollers found</ok>
      <ok>Python poller wrapper is polling</ok>
      <ok>rrd_dir is writable</ok>
      <ok>rrdtool version ok</ok>
      <warn>Local git contains modified files (expected — config files edited)</warn>
    </final-result>
  </validation>


  <!-- ══════════════════════════════════════════════════════
       MONITORED DEVICES
       ══════════════════════════════════════════════════════ -->
  <monitored-devices>
    <device id="1">
      <hostname>YOUR_SERVER_IP</hostname>
      <display-name>YOUR_HOSTNAME</display-name>
      <os>Ubuntu 22.04</os>
      <snmp-version>v2c</snmp-version>
      <community>YOUR_COMMUNITY_STRING</community>
      <port>161</port>
      <transport>UDP</transport>
      <role>LibreNMS server monitoring itself</role>
    </device>

    <device id="2">
      <hostname>YOUR_KALI_IP</hostname>
      <display-name>kali</display-name>
      <os>Kali Linux</os>
      <snmp-version>v2c</snmp-version>
      <community>YOUR_COMMUNITY_STRING</community>
      <port>161</port>
      <transport>UDP</transport>
      <role>Attack/monitoring VM — SNMP agent</role>
    </device>
  </monitored-devices>


